    "@warden/orchestrator": "workspace:*",
    "@actions/core": "^1.11.1",
    "@octokit/rest": "^21.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
