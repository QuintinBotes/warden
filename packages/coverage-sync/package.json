{
  "name": "@warden/coverage-sync",
  "version": "0.4.1",
  "description": "Warden cross-repo coverage sync — resolve linked repos, find test/doc gaps, publish suggestions",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@warden/core": "workspace:*",
    "@warden/test-management": "workspace:*",
    "js-yaml": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
