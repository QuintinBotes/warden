    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.5",
    "typescript": "^7.0.2"
  }
