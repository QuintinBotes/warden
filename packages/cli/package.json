{
  "name": "@warden/cli",
  "version": "0.2.0",
  "description": "Warden CLI — analyze, run, agent, report, plan, and init commands",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "warden": "./dist/bin/warden.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@warden/agent": "workspace:*",
    "@warden/core": "workspace:*",
    "@warden/cuj": "workspace:*",
    "@warden/impact": "workspace:*",
    "@warden/orchestrator": "workspace:*",
    "@warden/reporter": "workspace:*",
    "@warden/runner": "workspace:*",
    "@warden/test-management": "workspace:*",
    "@warden/vcs": "workspace:*",
    "@warden/visual": "workspace:*",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
