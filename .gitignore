# dependencies & build output
node_modules/
dist/
# Exception: the GitHub Action is consumed from a checkout with no node_modules, so its
# self-contained bundle MUST be committed (a CI job keeps it in sync with source).
!packages/github-action/dist/
!packages/github-action/dist/**
.turbo/
.next/
out/
*.tsbuildinfo

# logs & os
*.log
.DS_Store

# secrets & credentials — never commit these
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa*
credentials.json
secrets/

# local data & generated media
*.sqlite
*.sqlite3
.warden/
coverage/
playwright-report/
test-results/
