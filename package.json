{
  "name": "warden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Warden — open-source, AI-native QA platform",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "engines": { "node": ">=20" },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "better-sqlite3"]
  },
  "scripts": {
    "build": "pnpm --filter=./packages/* build",
    "typecheck": "pnpm --filter=./packages/* typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"packages/**/*.{ts,json}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
