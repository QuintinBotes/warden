{
  "name": "warden",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Warden — open-source, AI-native QA platform",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ],
    "overrides": {
      "undici": ">=6.27.0",
      "postcss": ">=8.5.10",
      "esbuild": ">=0.28.1",
      "tar": ">=7.5.16",
      "@opentelemetry/core": ">=2.8.0"
    }
  },
  "scripts": {
    "build": "pnpm --filter=./packages/* build",
    "typecheck": "pnpm --filter=./packages/* typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "prettier --check \"packages/**/*.{ts,json}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
