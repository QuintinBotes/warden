# Warden self-hosted stack — copy to deploy/.env and fill in.
# NEVER commit deploy/.env (it is gitignored).

# ── GitHub App: cross-repo coverage sync ───────────────────────────────────────
# Register a GitHub App (Settings → Developer settings → GitHub Apps → New).
#  - Permissions: Contents read/write, Pull requests write, Checks write.
#  - Subscribe to the "Pull request" event.
#  - Set the webhook URL to https://<your-host>:3002/api/github/webhooks
#  - Generate a private key (.pem) and a webhook secret.
GITHUB_APP_ID=
# Paste the .pem contents; multi-line keys may use escaped newlines (\n).
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_PATH=/api/github/webhooks

# The AI engine used to author test/doc suggestions.
ANTHROPIC_API_KEY=

# ── Observability ──────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
